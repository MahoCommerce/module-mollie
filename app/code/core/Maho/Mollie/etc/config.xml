<config>
    <modules>
        <Maho_Mollie>
            <version>1.1.0</version>
        </Maho_Mollie>
    </modules>

    <global>
        <models>
            <maho_mollie>
                <class>Maho_Mollie_Model</class>
            </maho_mollie>
        </models>

        <blocks>
            <maho_mollie>
                <class>Maho_Mollie_Block</class>
            </maho_mollie>
        </blocks>

        <helpers>
            <maho_mollie>
                <class>Maho_Mollie_Helper</class>
            </maho_mollie>
        </helpers>

        <resources>
            <maho_mollie_setup>
                <setup>
                    <module>Maho_Mollie</module>
                    <class>Mage_Sales_Model_Resource_Setup</class>
                </setup>
            </maho_mollie_setup>
        </resources>

        <sales>
            <quote>
                <totals>
                    <payment_fee>
                        <class>maho_mollie/quote_address_total_paymentFee</class>
                        <after>subtotal,shipping,tax,discount</after>
                        <before>grand_total</before>
                    </payment_fee>
                </totals>
            </quote>
        </sales>

        <events>
            <sales_model_service_quote_submit_before>
                <observers>
                    <maho_mollie_copy_payment_fee>
                        <class>maho_mollie/observer</class>
                        <method>copyPaymentFeeToOrder</method>
                    </maho_mollie_copy_payment_fee>
                </observers>
            </sales_model_service_quote_submit_before>
        </events>
    </global>

    <crontab>
        <jobs>
            <maho_mollie_check_pending_payments>
                <schedule>
                    <cron_expr>*/5 * * * *</cron_expr>
                </schedule>
                <run>
                    <model>maho_mollie/cron::checkPendingPayments</model>
                </run>
            </maho_mollie_check_pending_payments>
        </jobs>
    </crontab>

    <frontend>
        <routers>
            <mollie>
                <use>standard</use>
                <args>
                    <module>Maho_Mollie</module>
                    <frontName>mollie</frontName>
                </args>
            </mollie>
        </routers>
        <secure_url>
            <maho_mollie_payment>/mollie/payment</maho_mollie_payment>
            <maho_mollie_webhook>/mollie/webhook</maho_mollie_webhook>
        </secure_url>
        <translate>
            <modules>
                <Maho_Mollie>
                    <files>
                        <default>Maho_Mollie.csv</default>
                    </files>
                </Maho_Mollie>
            </modules>
        </translate>
    </frontend>

    <default>
        <maho_mollie>
            <credentials>
                <testmode>1</testmode>
                <api_key_live backend_model="adminhtml/system_config_backend_encrypted"/>
                <api_key_test backend_model="adminhtml/system_config_backend_encrypted"/>
            </credentials>
            <statuses>
                <order_status_pending>pending_payment</order_status_pending>
                <order_status_processing>processing</order_status_processing>
            </statuses>
            <payment_fee>
                <fee_type>disabled</fee_type>
                <fee_fixed>0</fee_fixed>
                <fee_percent>0</fee_percent>
                <fee_max></fee_max>
                <include_shipping>0</include_shipping>
                <include_discount>0</include_discount>
            </payment_fee>
        </maho_mollie>
        <payment>
            <mollie>
                <active>0</active>
                <model>maho_mollie/method_standard</model>
                <title>Mollie</title>
                <group>mollie</group>
                <allowspecific>0</allowspecific>
                <sort_order>100</sort_order>
                <fee_enabled>0</fee_enabled>
            </mollie>
            <mollie_ideal>
                <active>0</active>
                <model>maho_mollie/method_ideal</model>
                <title>iDEAL</title>
                <group>mollie</group>
                <allowspecific>0</allowspecific>
                <sort_order>101</sort_order>
                <fee_enabled>0</fee_enabled>
            </mollie_ideal>
            <mollie_bancontact>
                <active>0</active>
                <model>maho_mollie/method_bancontact</model>
                <title>Bancontact</title>
                <group>mollie</group>
                <allowspecific>0</allowspecific>
                <sort_order>102</sort_order>
                <fee_enabled>0</fee_enabled>
            </mollie_bancontact>
            <mollie_creditcard>
                <active>0</active>
                <model>maho_mollie/method_creditcard</model>
                <title>Credit Card</title>
                <group>mollie</group>
                <allowspecific>0</allowspecific>
                <sort_order>103</sort_order>
                <fee_enabled>0</fee_enabled>
            </mollie_creditcard>
            <mollie_paypal>
                <active>0</active>
                <model>maho_mollie/method_paypal</model>
                <title>PayPal</title>
                <group>mollie</group>
                <allowspecific>0</allowspecific>
                <sort_order>104</sort_order>
                <fee_enabled>0</fee_enabled>
            </mollie_paypal>
            <mollie_klarnapaylater>
                <active>0</active>
                <model>maho_mollie/method_klarnapaylater</model>
                <title>Klarna - Pay later</title>
                <group>mollie</group>
                <allowspecific>0</allowspecific>
                <sort_order>105</sort_order>
                <fee_enabled>0</fee_enabled>
            </mollie_klarnapaylater>
            <mollie_klarnapaynow>
                <active>0</active>
                <model>maho_mollie/method_klarnapaynow</model>
                <title>Klarna - Pay now</title>
                <group>mollie</group>
                <allowspecific>0</allowspecific>
                <sort_order>106</sort_order>
                <fee_enabled>0</fee_enabled>
            </mollie_klarnapaynow>
            <mollie_klarnasliceit>
                <active>0</active>
                <model>maho_mollie/method_klarnasliceit</model>
                <title>Klarna - Slice it</title>
                <group>mollie</group>
                <allowspecific>0</allowspecific>
                <sort_order>107</sort_order>
                <fee_enabled>0</fee_enabled>
            </mollie_klarnasliceit>
            <mollie_applepay>
                <active>0</active>
                <model>maho_mollie/method_applepay</model>
                <title>Apple Pay</title>
                <group>mollie</group>
                <allowspecific>0</allowspecific>
                <sort_order>108</sort_order>
                <fee_enabled>0</fee_enabled>
            </mollie_applepay>
        </payment>
    </default>
</config>

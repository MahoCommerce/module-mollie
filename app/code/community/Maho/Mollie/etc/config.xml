<config>
    <modules>
        <Maho_Mollie>
            <version>1.2.0</version>
        </Maho_Mollie>
    </modules>

    <global>
        <models>
            <maho_mollie>
                <class>Maho_Mollie_Model</class>
            </maho_mollie>
        </models>

        <blocks>
            <maho_mollie>
                <class>Maho_Mollie_Block</class>
            </maho_mollie>
        </blocks>

        <helpers>
            <maho_mollie>
                <class>Maho_Mollie_Helper</class>
            </maho_mollie>
        </helpers>

        <payment>
            <groups>
                <mollie>Mollie</mollie>
            </groups>
        </payment>
    </global>

    <admin>
        <routers>
            <adminhtml>
                <args>
                    <modules>
                        <Maho_Mollie before="Mage_Adminhtml">Maho_Mollie_Adminhtml</Maho_Mollie>
                    </modules>
                </args>
            </adminhtml>
        </routers>
    </admin>

    <frontend>
        <secure_url>
            <maho_mollie_payment>/mollie/payment</maho_mollie_payment>
            <maho_mollie_webhook>/mollie/webhook</maho_mollie_webhook>
        </secure_url>
        <layout>
            <updates>
                <maho_mollie>
                    <file>maho_mollie.xml</file>
                </maho_mollie>
            </updates>
        </layout>
        <translate>
            <modules>
                <Maho_Mollie>
                    <files>
                        <default>Maho_Mollie.csv</default>
                    </files>
                </Maho_Mollie>
            </modules>
        </translate>
    </frontend>

